# --- secrets -----------------------------------------------------------------
.env
.env.local
*.key

# --- data & build artefacts --------------------------------------------------
# The database is reproducible from `make build`; it is far too large for git.
data/raw/*
!data/raw/.gitkeep
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
*.sqlite
*.sqlite3

# Analysis outputs are regenerated by `make analyse`; the committed copies live
# in docs/analysis_report.md instead.
output/*.csv
output/*.json

# --- browser automation ------------------------------------------------------
scripts/.chrome-profile/
scripts/.shots/

# --- python ------------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# --- os / editor -------------------------------------------------------------
.DS_Store
.idea/
.vscode/
Thumbs.db
docs/analysis_results.partial-*.md
