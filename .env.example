# ---------------------------------------------------------------------------
# RailPulse — environment template
#
#   cp .env.example .env      and fill in your own subscription key.
#   .env is git-ignored;  never commit a real key.
# ---------------------------------------------------------------------------

# Subscription (API) key from the Belgian Mobility developer portal.
#   1. Create a free account ......... https://api-management-opendata-production.developer.azure-api.net/signup
#   2. Profile -> Products -> pick "Standard" -> name the subscription -> Subscribe
#   3. Copy the *Primary key* from the Subscriptions table.
# `scripts/setup_api_key.py` automates steps 2-3 for an existing account.
#
# The public endpoints also answer without a key, but anonymous callers are
# capped at 100 requests/day and 10 requests/minute. Always send the key.
BMC_API_KEY=

# Credentials used *only* by scripts/setup_api_key.py to drive the portal UI.
# Leave blank if you created the subscription by hand in the browser.
BMC_EMAIL=
BMC_PASSWORD=

# ---------------------------------------------------------------------------
# Optional overrides — every value below already has a sane default.
# ---------------------------------------------------------------------------
# RAILPULSE_DB=data/railpulse.db
# RAILPULSE_OPERATOR=nmbssncb
# RAILPULSE_API_BASE=https://api-management-discovery-production.azure-api.net
# RAILPULSE_MAX_RPM=10
